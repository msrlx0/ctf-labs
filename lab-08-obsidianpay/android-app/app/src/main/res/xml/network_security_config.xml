<?xml version="1.0" encoding="utf-8"?>
<!--
  Local-lab network policy. Cleartext (HTTP) is allowed ONLY for the emulator
  loopback host (10.0.2.2) and local hosts. Everything else stays HTTPS-only by
  Android defaults. Intentional for the lab; never ship this in production.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
