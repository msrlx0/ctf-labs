<%- include('partials/header', { title: 'Recover' }) %>

<section class="panel narrow">
  <p class="eyebrow">Fluxo de recuperacao</p>
  <h1>Recover</h1>
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>
  <% if (result) { %>
    <div class="success"><%= result %></div>
  <% } %>
  <form class="form-stack" action="/recover" method="post">
    <label>
      Identidade
      <input name="username" value="admin" required>
    </label>
    <label>
      Recovery code
      <input name="recovery_code" placeholder="4 caracteres" required>
    </label>
    <button type="submit">Validar codigo</button>
  </form>
  <p class="muted">A API auxiliar de verificacao fica em <code>/api/check-user</code>.</p>
</section>

<%- include('partials/footer') %>
