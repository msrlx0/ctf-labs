<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> - NeonVault</title>
  <link rel="stylesheet" href="/css/neon.css">
</head>
<body>
  <div class="neon-grid" aria-hidden="true"></div>
  <header class="topbar">
    <a class="brand" href="/">
      <img src="/img/neonvault-mark.svg" alt="" width="38" height="38">
      <span>
        <strong>NeonVault</strong>
        <small>Identity Grid</small>
      </span>
    </a>
    <nav class="nav" aria-label="Módulos NeonVault">
      <div class="nav-group">
        <span class="nav-label">Grid</span>
        <a href="/dashboard" class="<%= currentPath === '/dashboard' ? 'active' : '' %>">Dashboard</a>
        <a href="/profile" class="<%= currentPath === '/profile' ? 'active' : '' %>">Profile</a>
        <a href="/recover" class="<%= currentPath === '/recover' ? 'active' : '' %>">Recover</a>
      </div>
      <div class="nav-group">
        <span class="nav-label">Ops</span>
        <a href="/logs" class="<%= currentPath === '/logs' ? 'active' : '' %>">Logs</a>
        <a href="/files" class="<%= currentPath === '/files' || currentPath === '/download' ? 'active' : '' %>">Files</a>
      </div>
      <div class="nav-group">
        <span class="nav-label">Tools</span>
        <a href="/tools/webhook" class="<%= currentPath === '/tools/webhook' ? 'active' : '' %>">Webhook</a>
        <a href="/messages/preview" class="<%= currentPath === '/messages/preview' ? 'active' : '' %>">Preview</a>
        <a href="/avatar" class="<%= currentPath === '/avatar' ? 'active' : '' %>">Avatar</a>
        <a href="/admin/core" class="<%= currentPath === '/admin/core' ? 'active danger' : '' %>">Core</a>
      </div>
    </nav>
    <div class="session">
      <% if (currentUser) { %>
        <span class="chip"><%= currentUser.username %> :: <%= currentUser.role %></span>
        <form action="/logout" method="post">
          <button type="submit" class="link-button">Sair</button>
        </form>
      <% } else { %>
        <a class="button small" href="/login">Login</a>
      <% } %>
    </div>
  </header>
  <main class="shell">
