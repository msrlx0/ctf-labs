<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> - NeonVault</title>
  <link rel="stylesheet" href="/css/neon.css">
</head>
<body>
  <div class="neon-grid" aria-hidden="true"></div>
  <header class="topbar">
    <a class="brand" href="/">
      <img src="/img/neonvault-mark.svg" alt="" width="38" height="38">
      <span>
        <strong>NeonVault</strong>
        <small>Identity Grid</small>
      </span>
    </a>
    <nav class="nav">
      <a href="/dashboard">Dashboard</a>
      <a href="/recover">Recover</a>
      <a href="/logs">Logs</a>
      <a href="/files">Files</a>
      <a href="/tools/webhook">Webhook</a>
      <a href="/messages/preview">Preview</a>
      <a href="/avatar">Avatar</a>
      <a href="/admin/core">Core</a>
    </nav>
    <div class="session">
      <% if (currentUser) { %>
        <span class="chip"><%= currentUser.username %> :: <%= currentUser.role %></span>
        <form action="/logout" method="post">
          <button type="submit" class="link-button">Sair</button>
        </form>
      <% } else { %>
        <a class="button small" href="/login">Login</a>
      <% } %>
    </div>
  </header>
  <main class="shell">
