<%- include('partials/header', { title: 'Login' }) %>

<section class="auth-layout">
  <div class="panel">
    <p class="eyebrow">Acesso operacional</p>
    <h1>Login</h1>
    <p class="muted">Autenticacao do grid noturno para operadores NeonCore.</p>
    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>
    <form class="form-stack" action="/login" method="post">
      <label>
        Identidade
        <input name="username" autocomplete="username" required>
      </label>
      <label>
        Senha
        <input name="password" type="password" autocomplete="current-password" required>
      </label>
      <button type="submit">Autenticar</button>
    </form>
  </div>
  <aside class="panel side-panel">
    <p class="eyebrow">Turno liberado</p>
    <h2>Operador inicial</h2>
    <div class="credential-card">
      <span>identidade</span>
      <strong>nova</strong>
      <span>senha</span>
      <strong>nova2099</strong>
    </div>
    <p class="muted">O gateway principal filtra entradas ruidosas. Fluxos legados ainda ficam em modulos auxiliares.</p>
  </aside>
</section>

<%- include('partials/footer') %>
