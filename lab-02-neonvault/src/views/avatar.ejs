<%- include('partials/header', { title: 'Avatar' }) %>

<section class="panel narrow">
  <p class="eyebrow">Upload de identidade</p>
  <h1>Avatar</h1>
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>
  <% if (flag) { %>
    <div class="success"><%= flag %></div>
  <% } %>
  <% if (upload) { %>
    <div class="terminal">
      <p>Arquivo aceito: <%= upload.originalName %></p>
      <p>Cache: <a href="<%= upload.url %>"><%= upload.storedName %></a></p>
    </div>
  <% } %>
  <form class="form-stack" action="/avatar" method="post" enctype="multipart/form-data">
    <label>
      Arquivo de avatar
      <input type="file" name="avatar" required>
    </label>
    <button type="submit">Enviar asset</button>
  </form>
</section>

<%- include('partials/footer') %>
