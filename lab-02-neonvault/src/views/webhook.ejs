<%- include('partials/header', { title: 'Webhook' }) %>

<section class="panel">
  <p class="eyebrow">Ferramenta de integracao</p>
  <h1>Webhook Tester</h1>
  <p class="muted">Adaptadores internos respondem apenas de dentro do vault.</p>
  <form class="form-stack" action="/tools/webhook" method="post">
    <label>
      URL alvo
      <input name="url" value="<%= targetUrl %>" placeholder="https://example.com" required>
    </label>
    <button type="submit">Enviar teste</button>
  </form>
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>
  <% if (response) { %>
    <h2>Resposta</h2>
    <pre><code><%= response %></code></pre>
  <% } %>
</section>

<%- include('partials/footer') %>
