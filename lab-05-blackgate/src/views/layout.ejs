<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title ? `${title} - ${appName}` : appName %></title>
  <link rel="stylesheet" href="/static/css/style.css">
</head>
<body class="<%= currentUser ? 'app-shell' : 'auth-shell' %>">
  <% if (currentUser) { %>
    <%
      const baseLinks = {
        dashboard: { href: "/dashboard", label: "Dashboard" },
        tickets: { href: "/tickets", label: "Tickets" },
        assets: { href: "/assets", label: "Assets" },
        context: { href: "/context", label: "Context" },
        gateway: { href: "/gateway", label: "Gateway" },
        legacy: { href: "/legacy", label: "Legacy" },
        filesVault: { href: "/files-vault", label: "Files Vault" },
        health: { href: "/health", label: "Health" }
      };
      const navLinksByRole = {
        guest: [baseLinks.dashboard, baseLinks.tickets, baseLinks.assets],
        analyst: [baseLinks.dashboard, baseLinks.tickets, baseLinks.assets, baseLinks.context],
        operator: [baseLinks.dashboard, baseLinks.context, baseLinks.gateway, baseLinks.legacy, baseLinks.filesVault, baseLinks.tickets, baseLinks.assets, baseLinks.health],
        admin: [baseLinks.dashboard, baseLinks.context, baseLinks.gateway, baseLinks.legacy, baseLinks.filesVault, baseLinks.tickets, baseLinks.assets, baseLinks.health]
      };
      const navLinks = navLinksByRole[currentUser.role] || navLinksByRole.guest;
    %>
    <header class="topbar">
      <a class="brand" href="/dashboard" aria-label="BlackGate dashboard">
        <span class="brand-mark">BG</span>
        <span>
          <strong>BlackGate</strong>
          <small>Operations Console</small>
        </span>
      </a>
      <nav class="nav-links" aria-label="Navegacao principal">
        <% navLinks.forEach((link) => { %>
          <a class="<%= currentPath === link.href ? 'active' : '' %>" href="<%= link.href %>"><%= link.label %></a>
        <% }) %>
      </nav>
      <div class="session-pill">
        <span><%= currentUser.username %></span>
        <strong><%= currentUser.role %></strong>
        <a href="/logout">Logout</a>
      </div>
    </header>
  <% } %>

  <main class="<%= currentUser ? 'content' : 'auth-content' %>">
    <%- body %>
  </main>

  <script src="/static/js/app.js"></script>
</body>
</html>
