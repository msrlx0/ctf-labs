<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title ? `${title} - ${appName}` : appName %></title>
  <link rel="stylesheet" href="/static/css/style.css">
</head>
<body class="<%= currentUser ? 'app-shell' : 'auth-shell' %>">
  <!-- legacy migration note: debug prefix moved to /debug -->
  <% if (currentUser) { %>
    <header class="topbar">
      <a class="brand" href="/dashboard" aria-label="BlackGate dashboard">
        <span class="brand-mark">BG</span>
        <span>
          <strong>BlackGate</strong>
          <small>Operations Console</small>
        </span>
      </a>
      <nav class="nav-links" aria-label="Navegacao principal">
        <a class="<%= currentPath === '/dashboard' ? 'active' : '' %>" href="/dashboard">Dashboard</a>
        <a class="<%= currentPath === '/context' ? 'active' : '' %>" href="/context">Context</a>
        <a class="<%= currentPath === '/tickets' ? 'active' : '' %>" href="/tickets">Tickets</a>
        <a class="<%= currentPath === '/assets' ? 'active' : '' %>" href="/assets">Assets</a>
        <a href="/health">Health</a>
      </nav>
      <div class="session-pill">
        <span><%= currentUser.username %></span>
        <strong><%= currentUser.role %></strong>
        <a href="/logout">Logout</a>
      </div>
    </header>
  <% } %>

  <main class="<%= currentUser ? 'content' : 'auth-content' %>">
    <%- body %>
  </main>

  <script src="/static/js/app.js"></script>
</body>
</html>
