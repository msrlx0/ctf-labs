<section class="page-header">
  <div>
    <p class="eyebrow">Access Context</p>
    <h1>Operational Context</h1>
    <p>Operational context is evaluated separately from the web session for selected compatibility workflows.</p>
  </div>
  <div class="header-badge">
    <span>Issuer</span>
    <strong><%= contextPreview.issued_by %></strong>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <div class="panel-head">
      <h2>Sessão atual</h2>
      <span class="subtle">Express session</span>
    </div>
    <div class="kv-list">
      <div><span>Usuário</span><strong><%= currentUser.username %></strong></div>
      <div><span>Role</span><strong><%= currentUser.role %></strong></div>
      <div><span>Team</span><strong><%= currentUser.team %></strong></div>
    </div>
  </article>

  <article class="panel">
    <div class="panel-head">
      <h2>Contexto legado</h2>
      <span class="subtle">compatibility mode</span>
    </div>
    <div class="kv-list">
      <div><span>Context role</span><strong><%= contextPreview.role %></strong></div>
      <div><span>Scope</span><strong><%= contextPreview.scope %></strong></div>
      <div><span>Issuer</span><strong><%= contextPreview.issued_by %></strong></div>
    </div>
  </article>

  <article class="panel wide">
    <div class="panel-head">
      <h2>Operações</h2>
      <span class="subtle">Compatibility mode</span>
    </div>
    <p class="muted-copy">Legacy compatibility remains enabled for selected workflows. Some migration checks are handled outside the public console.</p>
  </article>
</section>
