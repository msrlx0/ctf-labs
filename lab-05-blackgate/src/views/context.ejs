<section class="page-header">
  <div>
    <p class="eyebrow">Access Context</p>
    <h1>BG-Context Token</h1>
    <p>Sistemas legados do BlackGate usam tokens de contexto para integrações internas e endpoints operacionais.</p>
  </div>
  <div class="header-badge">
    <span>Issuer</span>
    <strong><%= contextPreview.issued_by %></strong>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel">
    <div class="panel-head">
      <h2>Sessão atual</h2>
      <span class="subtle">Express session</span>
    </div>
    <div class="kv-list">
      <div><span>Usuário</span><strong><%= currentUser.username %></strong></div>
      <div><span>Role</span><strong><%= currentUser.role %></strong></div>
      <div><span>Team</span><strong><%= currentUser.team %></strong></div>
    </div>
  </article>

  <article class="panel">
    <div class="panel-head">
      <h2>Contexto legado</h2>
      <a href="/api/context/me">/api/context/me</a>
    </div>
    <div class="kv-list">
      <div><span>Context role</span><strong><%= contextPreview.role %></strong></div>
      <div><span>Scope</span><strong><%= contextPreview.scope %></strong></div>
      <div><span>Header</span><strong>X-BG-Context</strong></div>
    </div>
  </article>

  <article class="panel wide">
    <div class="panel-head">
      <h2>Operações</h2>
      <span class="subtle">Compatibility mode</span>
    </div>
    <p class="muted-copy">Legacy operator endpoints consume BG context headers. Use DevTools ou Burp para comparar a sessão web, o token de contexto e as respostas dos endpoints de validação.</p>
  </article>
</section>
